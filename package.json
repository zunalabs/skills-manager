{
  "name": "skills-manager",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:desktop": "turbo dev --filter=apps/desktop",
    "dev:web": "turbo dev --filter=apps/web",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.7.5"
  }
}
