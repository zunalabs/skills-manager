{
  "name": "skills-manager",
  "version": "0.1.0",
  "description": "Desktop app for managing AI agent skills",
  "author": {
    "name": "Zunalabs",
    "email": "hello@zunalabs.com"
  },
  "homepage": "https://sm.idoevergreen.me",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "preelectron:dev": "node scripts/gen-icon.js",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "preelectron:build": "node scripts/gen-icon.js",
    "electron:build": "vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "7zip-bin": "^5.2.0",
    "app-builder-bin": "^4.0.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "28.3.3",
    "electron-builder": "^25.1.8",
    "playwright": "^1.58.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^1.6.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.zunalabs.skills-manager",
    "productName": "Skills Manager",
    "copyright": "Copyright © 2025 Zunalabs",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.ts}",
      "!**/node_modules/.bin"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Skills Manager"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "Skills-Manager-Setup.exe"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "artifactName": "Skills-Manager-linux-${arch}.${ext}",
      "maintainer": "Zunalabs <hello@zunalabs.com>"
    },
    "publish": {
      "provider": "github",
      "owner": "zunalabs",
      "repo": "skills-manager"
    }
  }
}
