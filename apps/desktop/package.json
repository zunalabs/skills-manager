{
  "name": "skills-manager",
  "version": "0.1.0",
  "description": "Desktop app for managing AI agent skills",
  "author": "Zunalabs",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.294.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.16",
    "7zip-bin": "^5.2.0",
    "app-builder-bin": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "28.3.3",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.zunalabs.skills-manager",
    "productName": "Skills Manager",
    "copyright": "Copyright © 2025 Zunalabs",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.ts}",
      "!**/node_modules/.bin"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "Skills Manager"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "Skills-Manager-Setup.exe"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "zunalabs",
      "repo": "skills-manager"
    }
  }
}
